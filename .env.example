# .env.example
# Template for all Nativa environment variables.
# Copy this file to .env and fill in the values before running docker-compose.
#
# SECURITY: Never commit the real .env to version control.
# The .gitignore should already exclude .env.

# --- Telegram Bot -----------------------------------------------------------

# Bot token from @BotFather (e.g. 123456789:AAB...)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Publicly accessible HTTPS URL where the Mini-App frontend is served.
# Must use HTTPS - Telegram rejects http:// WebApp URLs.
# Example: https://nativa.yourdomain.com
MINI_APP_URL=https://your-mini-app-url.com

# Internal backend URL used by bot service in Docker
BACKEND_URL=http://backend:8000

# --- PostgreSQL -------------------------------------------------------------

# Database name (created automatically on first start)
POSTGRES_DB=nativa

# Database user
POSTGRES_USER=nativa

# Strong random password - generate with: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_strong_password

# Full async SQLAlchemy connection URL.
# Docker compose default (backend container -> db service):
DATABASE_URL=postgresql+asyncpg://nativa:change_me_strong_password@db:5432/nativa

# --- Redis -----------------------------------------------------------------

# Docker compose default (backend container -> redis service)
REDIS_URL=redis://redis:6379/0

# --- FastAPI / Backend ------------------------------------------------------

# Secret key used to sign session cookies and internal tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_secret_key_32_bytes_hex

# Environment name: "development" | "production"
APP_ENV=development

# Backend server host/port (used by uvicorn start command)
HOST=0.0.0.0
PORT=8000

# Number of uvicorn worker processes (production: set to CPU count)
WORKERS=1

# --- AI / Gemini ------------------------------------------------------------

# Google Gemini API key used by grammar explanation service
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Cloud / YouTube -------------------------------------------------

# Path to Google Cloud service account JSON key file (optional)
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google_credentials.json

# Google API key for Translation / TTS
GOOGLE_API_KEY=your_google_api_key_here

# YouTube Data API v3 key (used for title/duration metadata)
YOUTUBE_API_KEY=your_youtube_api_key_here

# --- Firebase (Speaking Match Signaling) -----------------------------------

# Absolute path to Firebase service-account JSON file
FIREBASE_CREDENTIALS=/app/secrets/firebase_credentials.json

# --- Cloudflare R2 (TTS Audio Storage) -------------------------------------

# Cloudflare account ID for R2 endpoint
R2_ACCOUNT_ID=your_r2_account_id_here

# R2 S3-compatible access key pair
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here

# Bucket name and public URL prefix for uploaded audio
R2_BUCKET_NAME=nativa-audio
R2_PUBLIC_URL=https://your-r2-public-url.example.com

# --- Freemium Limits --------------------------------------------------------

# Maximum word translations per day for free users (429 above this)
FREE_TRANSLATE_LIMIT=20

# Maximum AI explanation requests per day for free users
FREE_AI_LIMIT=5

# --- Payment (Telegram Stars) ----------------------------------------------

# Price in Telegram Stars for the monthly premium subscription
PREMIUM_STARS_PRICE=200

# Payload label embedded in the invoice (must be unique per product)
PREMIUM_INVOICE_PAYLOAD=nativa_premium_monthly

# --- CORS ------------------------------------------------------------------

# Comma-separated list of allowed CORS origins (used in development)
# In production, nginx handles CORS - this can be left empty.
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
